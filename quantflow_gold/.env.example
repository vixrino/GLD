# QuantFlow Gold — copy to `.env` in repo root or next to `quantflow_gold/`
#   cp quantflow_gold/.env.example .env

# ----- Obligatoire pour la macro FRED (yields, DXY, CPI, gold LBMA fix, etc.) -----
# Clé gratuite : https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=db2ebd5b3fe85fdec3de3d0ff0c11d62

# ----- SEC EDGAR (recommandé : user-agent avec email réel) -----
SEC_USER_AGENT=QuantFlow Fund datamanager@example.com

# ----- Optionnel -----
# YOUTUBE_API_KEY=
# TIINGO_API_KEY=

# ----- Chemins -----
# Dossier parent de `processed/` (même convention que le notebook après load_dotenv).
# Préférez un chemin ABSOLU pour éviter les écritures dans ~/data selon le cwd du terminal.
# Exemple : DATA_DIR=/Users/vous/datascrap/data
DATA_DIR=../data
LOG_LEVEL=INFO
